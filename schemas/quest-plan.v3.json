{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/quest-plan.v3.json",
  "title": "Loopo Quest Plan v3",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "slug",
    "quest_id",
    "prompt",
    "summary",
    "assumptions",
    "tasks"
  ],
  "properties": {
    "schema_version": { "const": 3 },
    "slug": { "type": "string" },
    "quest_id": { "type": "string" },
    "prompt": { "type": "string" },
    "summary": { "type": "string" },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "tasks": { "type": "array" }
  }
}
