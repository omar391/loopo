{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/system-behaviours.v1.json",
  "title": "Loopo System Behaviours v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "behaviours", "pending_proposals"],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "behaviours": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "statement", "test_refs"],
        "properties": {
          "id": {
            "type": "string"
          },
          "statement": {
            "type": "string"
          },
          "test_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "pending_proposals": {
      "type": "array"
    }
  }
}
