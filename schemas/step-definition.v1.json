{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loopo.dev/schemas/step-definition.v1.json",
  "title": "Loopo Step Definition YAML v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "handler",
    "input_step",
    "input_schema",
    "output_schema",
    "summary",
    "instructions"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "handler": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "input_step": {
      "type": ["string", "null"],
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "input_schema": {
      "type": ["string", "null"],
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "output_schema": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "instructions": {
      "type": "string",
      "minLength": 1
    }
  }
}
