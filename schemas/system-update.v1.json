{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loopo.dev/schemas/system-update.v1.json",
  "title": "Loopo System Update v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "updates"],
  "properties": {
    "schema_version": { "const": 1 },
    "updates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["doc_id", "summary"],
        "properties": {
          "doc_id": {
            "enum": [
              "high-level-design",
              "low-level-design",
              "architecture",
              "system-behaviours",
              "design-system"
            ]
          },
          "summary": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  }
}
