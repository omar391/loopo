{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loopo.dev/schemas/system-architecture.v1.json",
  "title": "Loopo Architecture Doc v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "id", "type", "title", "status", "sections"],
  "properties": {
    "schema_version": { "const": 1 },
    "id": { "const": "architecture" },
    "type": { "const": "architecture" },
    "title": { "type": "string" },
    "status": { "type": "string" },
    "sections": { "type": "array" },
    "updated_at": { "type": ["string", "null"] }
  }
}
