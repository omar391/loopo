{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loopo.dev/schemas/merge-lease.v1.json",
  "title": "Loopo Merge Lease v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "lease_id",
    "task_id",
    "holder",
    "merge_target",
    "status"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "lease_id": { "type": "string" },
    "task_id": { "type": "string" },
    "holder": { "type": "string" },
    "merge_target": { "type": "string" },
    "status": { "enum": ["active", "merged", "blocked", "expired"] }
  }
}
