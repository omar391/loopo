{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loopo.dev/schemas/steps/questions-input.v3.json",
  "title": "Loopo V3 Question Answers Input",
  "type": "object",
  "additionalProperties": false,
  "required": ["step", "answers"],
  "properties": {
    "step": { "const": "questions" },
    "answers": {
      "type": "array",
      "items": {
        "$ref": "https://loopo.dev/schemas/steps/common.v3.json#/$defs/answer"
      }
    }
  }
}
