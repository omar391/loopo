{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loopo.dev/schemas/steps/help-output.v3.json",
  "title": "Loopo V3 Help Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "schema_id",
    "step",
    "state",
    "summary",
    "guide",
    "schemas",
    "flows",
    "commands"
  ],
  "properties": {
    "schema_version": { "const": 3 },
    "kind": { "const": "help" },
    "schema_id": {
      "const": "https://loopo.dev/schemas/steps/help-output.v3.json"
    },
    "step": { "const": "help" },
    "state": { "const": "help" },
    "summary": { "type": "string" },
    "guide": {
      "type": "object",
      "additionalProperties": false,
      "required": ["purpose", "launcher", "rules", "commands"],
      "properties": {
        "purpose": { "type": "string" },
        "launcher": { "type": "string" },
        "rules": {
          "type": "array",
          "items": { "type": "string" }
        },
        "commands": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "command", "use"],
            "properties": {
              "name": { "type": "string" },
              "command": { "type": "string" },
              "use": { "type": "string" }
            }
          }
        }
      }
    },
    "schemas": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "schema_id", "schema_path"],
        "properties": {
          "name": { "type": "string" },
          "schema_id": { "type": "string" },
          "schema_path": { "type": "string" }
        }
      }
    },
    "flows": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "version", "default_stage", "stages", "subflows"],
        "properties": {
          "id": { "type": "string" },
          "version": { "type": "integer" },
          "default_stage": { "type": "string" },
          "stages": {
            "type": "array",
            "items": { "type": "string" }
          },
          "subflows": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "commands": {
      "type": "object",
      "additionalProperties": false,
      "required": ["init", "next", "help", "hook"],
      "properties": {
        "init": {
          "$ref": "https://loopo.dev/schemas/steps/common.v3.json#/$defs/command"
        },
        "next": {
          "$ref": "https://loopo.dev/schemas/steps/common.v3.json#/$defs/command"
        },
        "help": {
          "$ref": "https://loopo.dev/schemas/steps/common.v3.json#/$defs/command"
        },
        "hook": {
          "$ref": "https://loopo.dev/schemas/steps/common.v3.json#/$defs/command"
        }
      }
    }
  }
}
