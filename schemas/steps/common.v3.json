{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/steps/common.v3.json",
  "title": "Loopo V3 Step Schema Common Definitions",
  "$defs": {
    "string_array": {
      "type": "array",
      "items": { "type": "string" }
    },
    "schema_ref": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["schema_path"],
          "properties": {
            "schema_path": { "type": "string" }
          }
        }
      ]
    },
    "embedded_schema": {
      "type": "object",
      "additionalProperties": true,
      "required": ["$schema", "$id"],
      "properties": {
        "$schema": { "type": "string" },
        "$id": { "type": "string" },
        "title": { "type": "string" },
        "type": {},
        "required": {
          "type": "array",
          "items": { "type": "string" }
        },
        "properties": { "type": "object" }
      }
    },
    "schema_ref_or_embedded": {
      "oneOf": [
        { "$ref": "#/$defs/schema_ref" },
        { "$ref": "#/$defs/embedded_schema" }
      ]
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cmd", "args"],
      "properties": {
        "cmd": { "type": "string" },
        "args": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "step_commands": {
      "type": "object",
      "additionalProperties": false,
      "required": ["next"],
      "properties": {
        "next": { "$ref": "#/$defs/command" }
      }
    },
    "docs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state_yaml", "plan_yaml", "manifest"],
      "properties": {
        "state_yaml": { "type": "string" },
        "plan_yaml": { "type": "string" },
        "manifest": { "type": "string" }
      }
    },
    "transitions": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "step_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "id",
        "handler",
        "input_step",
        "callback_schema",
        "output_schema",
        "summary",
        "instructions"
      ],
      "properties": {
        "schema_version": { "const": 1 },
        "id": { "type": "string" },
        "handler": { "type": "string" },
        "input_step": {
          "type": ["string", "null"]
        },
        "callback_schema": {
          "oneOf": [{ "$ref": "#/$defs/embedded_schema" }, { "type": "null" }]
        },
        "output_schema": { "type": "string" },
        "summary": { "type": "string" },
        "instructions": { "type": "string" }
      }
    },
    "step_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step"],
      "properties": {
        "step": { "$ref": "#/$defs/step_data" }
      }
    },
    "compact_step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "instructions"],
      "properties": {
        "id": { "type": "string" },
        "instructions": { "type": "string" }
      }
    },
    "task_graph_task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "acceptance"],
      "properties": {
        "id": { "type": "string" },
        "task_id": { "type": "string" },
        "title": { "type": "string" },
        "name": { "type": "string" },
        "type": { "enum": ["coding", "general"] },
        "status": { "type": "string" },
        "dependencies": { "$ref": "#/$defs/string_array" },
        "depends_on": { "$ref": "#/$defs/string_array" },
        "scope_files": { "$ref": "#/$defs/string_array" },
        "scope": { "$ref": "#/$defs/string_array" },
        "spec_refs": { "$ref": "#/$defs/string_array" },
        "specs": { "$ref": "#/$defs/string_array" },
        "context_refs": { "$ref": "#/$defs/string_array" },
        "context": { "$ref": "#/$defs/string_array" },
        "branch_ref": { "type": "string" },
        "worktree_path": { "type": "string" },
        "child_slug": { "type": "string" },
        "concurrency_group": { "type": "string" },
        "merge_target": { "type": "string" },
        "merge_lease_id": { "type": "string" },
        "merge_commit": { "type": "string" },
        "system_impact_ref": { "type": "string" },
        "acceptance": {
          "oneOf": [{ "type": "string" }, { "$ref": "#/$defs/string_array" }]
        },
        "acceptance_criteria": {
          "oneOf": [{ "type": "string" }, { "$ref": "#/$defs/string_array" }]
        }
      }
    },
    "question": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "question"],
      "properties": {
        "id": { "type": "string" },
        "question": { "type": "string" },
        "impact": { "type": "string" },
        "default": { "type": "string" }
      }
    },
    "answer": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["answer"],
          "properties": {
            "id": { "type": "string" },
            "question_id": { "type": "string" },
            "question": { "type": "string" },
            "answer": { "type": "string" },
            "accepted_default": { "type": "boolean" }
          }
        }
      ]
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "ref"],
      "properties": {
        "type": { "type": "string" },
        "ref": { "type": "string" },
        "summary": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "status"],
      "properties": {
        "name": { "type": "string" },
        "status": { "enum": ["passed", "failed", "skipped"] },
        "summary": { "type": "string" },
        "ref": { "type": "string" }
      }
    },
    "acceptance_trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["acceptance", "status"],
      "properties": {
        "acceptance": { "type": "string" },
        "status": { "enum": ["passed", "failed", "skipped"] },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence" }
        },
        "summary": { "type": "string" }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["risk"],
      "properties": {
        "risk": { "type": "string" },
        "severity": { "enum": ["low", "medium", "high"] },
        "mitigation": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "child": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_id",
        "title",
        "child_slug",
        "branch_ref",
        "worktree_path",
        "acceptance",
        "commands",
        "result_schema"
      ],
      "properties": {
        "task_id": { "type": "string" },
        "title": { "type": "string" },
        "child_slug": { "type": "string" },
        "branch_ref": { "type": "string" },
        "worktree_path": { "type": "string" },
        "acceptance": { "type": "string" },
        "commands": {
          "type": "object",
          "additionalProperties": false,
          "required": ["init", "next"],
          "properties": {
            "init": { "$ref": "#/$defs/command" },
            "next": { "$ref": "#/$defs/command" }
          }
        },
        "result_schema": { "$ref": "#/$defs/schema_ref_or_embedded" }
      }
    }
  }
}
