{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/steps/child-result-input.v3.json",
  "title": "Loopo V3 Child Result Input",
  "type": "object",
  "additionalProperties": false,
  "required": ["step", "task_id", "child_slug", "status", "evidence"],
  "allOf": [
    {
      "if": {
        "properties": {
          "status": { "const": "passed" }
        }
      },
      "then": {
        "required": ["merge_commit"]
      }
    }
  ],
  "properties": {
    "step": { "const": "child_result" },
    "task_id": { "type": "string" },
    "child_slug": { "type": "string" },
    "status": { "enum": ["passed", "blocked", "failed"] },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "common.v3.json#/$defs/evidence"
      }
    },
    "branch_ref": { "type": "string" },
    "worktree_path": { "type": "string" },
    "merge_target": { "type": "string" },
    "merge_lease_id": { "type": "string" },
    "merge_commit": { "type": "string" }
  }
}
