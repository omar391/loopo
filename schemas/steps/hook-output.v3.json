{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/steps/hook-output.v3.json",
  "title": "Loopo V3 Runtime Hook Output",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "decision": { "type": "string" },
    "reason": { "type": "string" },
    "suppressOutput": { "type": "boolean" },
    "hookSpecificOutput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hookEventName", "decision", "reason"],
      "properties": {
        "hookEventName": { "type": "string" },
        "decision": { "type": "string" },
        "reason": { "type": "string" }
      }
    }
  }
}
