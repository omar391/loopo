{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loopo.dev/schemas/steps/validation-input.v3.json",
  "title": "Loopo V3 Validation Input",
  "type": "object",
  "additionalProperties": false,
  "required": ["step", "status", "checks"],
  "properties": {
    "step": { "const": "validation" },
    "status": { "enum": ["passed", "failed"] },
    "checks": {
      "type": "array",
      "items": {
        "$ref": "https://loopo.dev/schemas/steps/common.v3.json#/$defs/check"
      }
    }
  }
}
