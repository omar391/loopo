{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/steps/next-input.v3.json",
  "title": "Loopo V3 Quest Next Input",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "action", "wtree", "request"],
      "properties": {
        "step": { "const": "select_quest" },
        "action": { "const": "create_quest" },
        "wtree": { "type": "string" },
        "flow_id": { "type": "string" },
        "request": { "type": "string" }
      }
    },
    { "$ref": "plan-input.v3.json" },
    { "$ref": "questions-input.v3.json" },
    { "$ref": "task-graph-input.v3.json" },
    { "$ref": "child-result-input.v3.json" },
    { "$ref": "validation-input.v3.json" },
    { "$ref": "verification-input.v3.json" },
    { "$ref": "system-update-input.v3.json" },
    { "$ref": "landing-input.v3.json" }
  ]
}
