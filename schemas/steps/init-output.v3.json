{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loopo.dev/schemas/steps/init-output.v3.json",
  "title": "Loopo V3 Init Route Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "schema_id",
    "request",
    "cwd",
    "runtime",
    "flow_id",
    "flow_version",
    "candidates",
    "new_quest",
    "help"
  ],
  "properties": {
    "schema_version": { "const": 3 },
    "kind": { "const": "init_route" },
    "schema_id": {
      "const": "https://loopo.dev/schemas/steps/init-output.v3.json"
    },
    "request": { "type": "string" },
    "cwd": { "type": "string" },
    "runtime": { "type": "string" },
    "flow_id": { "type": "string" },
    "flow_version": { "type": "integer" },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "slug",
          "score",
          "description",
          "state",
          "current_step",
          "flow_id",
          "flow_version",
          "worktree_path",
          "command"
        ],
        "properties": {
          "slug": { "type": "string" },
          "score": { "type": "number" },
          "description": { "type": "string" },
          "state": { "type": "string" },
          "current_step": { "type": "string" },
          "flow_id": { "type": "string" },
          "flow_version": { "type": "integer" },
          "worktree_path": { "type": "string" },
          "command": {
            "$ref": "https://loopo.dev/schemas/steps/common.v3.json#/$defs/command"
          }
        }
      }
    },
    "new_quest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["suggested_slug", "command", "callback_schema", "input"],
      "properties": {
        "suggested_slug": { "type": "string" },
        "command": {
          "$ref": "https://loopo.dev/schemas/steps/common.v3.json#/$defs/command"
        },
        "callback_schema": {
          "$ref": "https://loopo.dev/schemas/steps/common.v3.json#/$defs/embedded_schema"
        },
        "input": {
          "type": "object",
          "additionalProperties": false,
          "required": ["step", "action", "slug", "flow_id", "request"],
          "properties": {
            "step": { "const": "select_quest" },
            "action": { "const": "create_quest" },
            "slug": { "type": "string" },
            "flow_id": { "type": "string" },
            "request": { "type": "string" }
          }
        }
      }
    },
    "help": {
      "$ref": "https://loopo.dev/schemas/steps/common.v3.json#/$defs/command"
    }
  }
}
