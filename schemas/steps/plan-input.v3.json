{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loopo.dev/schemas/steps/plan-input.v3.json",
  "title": "Loopo V3 Plan Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "step",
    "classification",
    "scope",
    "af",
    "of",
    "verification_targets",
    "task_graph"
  ],
  "properties": {
    "step": { "const": "plan" },
    "classification": {
      "enum": ["greenfield_app", "feature", "bugfix", "refactor", "general"]
    },
    "scope": { "type": "string" },
    "summary": { "type": "string" },
    "clarification_matrix": {
      "type": "array",
      "items": {
        "$ref": "https://loopo.dev/schemas/steps/common.v3.json#/$defs/question"
      }
    },
    "high_impact_unknowns": {
      "$ref": "https://loopo.dev/schemas/steps/common.v3.json#/$defs/string_array"
    },
    "defaulted_unknowns": {
      "$ref": "https://loopo.dev/schemas/steps/common.v3.json#/$defs/string_array"
    },
    "assumptions": {
      "$ref": "https://loopo.dev/schemas/steps/common.v3.json#/$defs/string_array"
    },
    "constraints": {
      "$ref": "https://loopo.dev/schemas/steps/common.v3.json#/$defs/string_array"
    },
    "questions": {
      "type": "array",
      "items": {
        "$ref": "https://loopo.dev/schemas/steps/common.v3.json#/$defs/question"
      }
    },
    "af": {
      "type": "object"
    },
    "of": {
      "type": "object"
    },
    "verification_targets": {
      "$ref": "https://loopo.dev/schemas/steps/common.v3.json#/$defs/string_array"
    },
    "task_graph": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tasks"],
      "properties": {
        "tasks": {
          "type": "array",
          "items": {
            "$ref": "https://loopo.dev/schemas/steps/common.v3.json#/$defs/task_graph_task"
          }
        }
      }
    }
  }
}
