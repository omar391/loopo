{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/flow.v1.json",
  "title": "Loopo Flow YAML v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "version",
    "default_stage",
    "stages",
    "subflows"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "default_stage": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/stage" }
    },
    "subflows": {
      "type": "array",
      "items": { "$ref": "#/$defs/subflow" }
    }
  },
  "$defs": {
    "stage_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "step_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "transition_name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "stage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "step", "transitions"],
      "properties": {
        "id": { "$ref": "#/$defs/stage_id" },
        "step": { "$ref": "#/$defs/step_id" },
        "transitions": {
          "type": "object",
          "propertyNames": { "$ref": "#/$defs/transition_name" },
          "additionalProperties": { "$ref": "#/$defs/stage_id" }
        }
      }
    },
    "base_subflow": {
      "type": "object",
      "required": ["id", "type", "starts_at", "returns_to", "trigger"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "starts_at": { "$ref": "#/$defs/stage_id" },
        "returns_to": { "$ref": "#/$defs/stage_id" },
        "trigger": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "in_flow_detour": {
      "allOf": [
        { "$ref": "#/$defs/base_subflow" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "id": true,
            "type": { "const": "in_flow_detour" },
            "starts_at": true,
            "returns_to": true,
            "trigger": true
          }
        }
      ]
    },
    "spawned_quest": {
      "allOf": [
        { "$ref": "#/$defs/base_subflow" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "result_step", "flow_id"],
          "properties": {
            "id": true,
            "type": { "const": "spawned_quest" },
            "starts_at": true,
            "returns_to": true,
            "trigger": true,
            "result_step": { "$ref": "#/$defs/step_id" },
            "flow_id": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_-]*$"
            }
          }
        }
      ]
    },
    "subflow": {
      "oneOf": [
        { "$ref": "#/$defs/in_flow_detour" },
        { "$ref": "#/$defs/spawned_quest" }
      ]
    }
  }
}
